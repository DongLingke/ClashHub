# ClashHub 环境变量样例
# 使用：  cp .env.example .env  然后按实际情况填值
# 这个文件可以进版本库；.env 含密码，已被 .gitignore 排除。

# ===== 路由器（ShellCrash / mihomo） =====
# SSH 登录路由器，用于下发 Router.yaml + 重启 clash 服务
ROUTER_HOST=192.168.5.1
ROUTER_PORT=22
ROUTER_USER=root
ROUTER_PASSWORD=                                # 必填：路由器 root 密码

# 路由器上 mihomo 的实际配置文件路径（ShellCrash 默认是这个）
ROUTER_CONFIG_PATH=/tmp/ShellCrash/config.yaml

# 重启命令；非交互 SSH 里 crash 这个 alias 不会展开，所以要用 menu.sh 绝对路径
ROUTER_RESTART_CMD=/data/other_vol/ShellCrash/menu.sh -s restart

# ===== Clash 控制 API（external-controller） =====
# 路由器上 mihomo 的 RESTful API 地址。ShellCrash 默认 :9999 同端口承载 UI 和 API
CLASH_API_BASE=http://192.168.5.1:9999

# 如果你的 mihomo 设了 secret，填这里；空则不带 Authorization 头
CLASH_API_SECRET=
